# ========================
# GEMINI AI
# ========================
# Obtén tu API Key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here   # misma clave que GEMINI_API_KEY

# ========================
# CONFIGURACIÓN DEL AGENTE
# ========================
# Solo procesar correos llegados después de esta fecha (formato: YYYY/MM/DD)
GMAIL_FILTER_AFTER_DATE=2024/01/01

# Máximo de correos a procesar por ciclo
MAX_EMAILS_PER_RUN=20

# Cada cuántos minutos revisar el correo automáticamente
CHECK_INTERVAL_MINUTES=30

# ========================
# HORARIO DE DESCANSO
# ========================
# El agente no procesará correos en este rango horario (formato: 0-23)
QUIET_HOURS_START=0
QUIET_HOURS_END=8
