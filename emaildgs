#!/bin/bash
# =============================================================================
# emaildgs — Levanta el gmail-ai-agent (backend + frontend) y abre el navegador
#
# Uso:
#   emaildgs          (desde cualquier directorio)
#
# Para detener: Ctrl+C
# =============================================================================

# Directorio raíz del proyecto (resuelto desde el symlink real)
PROJECT_DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
BACKEND_DIR="$PROJECT_DIR/backend"
FRONTEND_DIR="$PROJECT_DIR/frontend"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "=================================================="
echo "  Gmail AI Agent — Iniciando servicios..."
echo "=================================================="
echo ""

# ── Verificar entorno virtual del backend ─────────────────────────────────────
if [ ! -d "$BACKEND_DIR/.venv" ]; then
    echo -e "${YELLOW}[!] Entorno virtual no encontrado. Creándolo...${NC}"
    python3 -m venv "$BACKEND_DIR/.venv"
    source "$BACKEND_DIR/.venv/bin/activate"
    pip install -r "$BACKEND_DIR/requirements.txt" -q
    echo -e "${GREEN}[✓] Dependencias del backend instaladas.${NC}"
fi

# ── Verificar node_modules del frontend ──────────────────────────────────────
if [ ! -d "$FRONTEND_DIR/node_modules" ]; then
    echo -e "${YELLOW}[!] node_modules no encontrado. Instalando dependencias...${NC}"
    cd "$FRONTEND_DIR" && npm install -q
    echo -e "${GREEN}[✓] Dependencias del frontend instaladas.${NC}"
fi

# ── Iniciar el backend ────────────────────────────────────────────────────────
echo -e "${GREEN}[1/2] Iniciando backend (FastAPI + uvicorn)...${NC}"
source "$BACKEND_DIR/.venv/bin/activate"
cd "$BACKEND_DIR" && python main.py &
BACKEND_PID=$!

sleep 3

# ── Iniciar el frontend ───────────────────────────────────────────────────────
echo -e "${GREEN}[2/2] Iniciando frontend (React + Vite)...${NC}"
cd "$FRONTEND_DIR" && npm run dev -- --port 5173 &
FRONTEND_PID=$!

# Esperar a que Vite esté listo y abrir el navegador
sleep 3
echo -e "${GREEN}[✓] Abriendo navegador...${NC}"
open http://localhost:5173

# ── Info ──────────────────────────────────────────────────────────────────────
echo ""
echo "=================================================="
echo -e "${GREEN}  Servicios activos:${NC}"
echo ""
echo -e "  Frontend  →  ${GREEN}http://localhost:5173${NC}"
echo -e "  Backend   →  ${GREEN}http://localhost:8000${NC}"
echo -e "  API docs  →  ${GREEN}http://localhost:8000/docs${NC}"
echo ""
echo "  Presiona Ctrl+C para detener todo."
echo "=================================================="
echo ""

# ── Limpiar al salir con Ctrl+C ───────────────────────────────────────────────
trap "echo ''; echo 'Deteniendo servicios...'; kill $BACKEND_PID $FRONTEND_PID 2>/dev/null; exit 0" SIGINT SIGTERM

wait $BACKEND_PID $FRONTEND_PID
